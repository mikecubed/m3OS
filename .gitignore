# Build artifacts
/target/

# Cargo lock is checked in for reproducible builds
# (uncomment to ignore: !Cargo.lock)

# Disk images and UEFI boot artifacts
*.img
*.iso
*.efi
/m3os.key
/m3os.crt

# Generated userspace ELF binaries (produced by cargo xtask / build_userspace_bins).
# Also includes musl-compiled C binaries (build_musl_bins).
# Built from source at build time; committing binaries creates noisy diffs.
/kernel/initrd/*.elf

# QEMU runtime files
*.qcow2
*.fd
OVMF*.fd
boot*.log

# Editor and IDE files
*.swp
*.swo
*~
.vscode/
.idea/

# OS-specific files
.DS_Store
Thumbs.db
sunset-local/
