# Build artifacts
/target/

# Cargo lock is checked in for reproducible builds
# (uncomment to ignore: !Cargo.lock)

# Disk images and UEFI boot artifacts
*.img
*.iso
*.efi
/m3os.key
/m3os.crt

# Generated initrd binaries are now staged under target/generated-initrd/ by
# cargo xtask, so /target covers them.

# Local agent/orchestration session artifacts
.agent/
.workflow-orchestration/artifacts/
.codex/
.claude/scheduled_tasks.lock

# Local debug captures (cargo xtask run > foo.log etc.)
*.log
output*.txt

# QEMU runtime files
*.qcow2
*.fd
OVMF*.fd
boot*.log

# Editor and IDE files
*.swp
*.swo
*~
.vscode/
.idea/

# OS-specific files
.DS_Store
Thumbs.db

# DOOM shareware WAD (auto-downloaded to target/; not committed)
doom1.wad
