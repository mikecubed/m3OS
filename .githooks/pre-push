#!/bin/sh
# Pre-push hook: run full quality gates before pushing to remote.
#
# The PR CI gate only runs static checks (clippy/fmt/host tests/loom) because
# GitHub's 2-vCPU shared runners can't execute TCG-emulated QEMU workloads
# reliably under Phase 54's IPC-heavy VFS. Full-system tests run here on
# developer hardware instead (and in the nightly workflow for scheduled
# coverage).
#
# Skipping the QEMU gates is not supported. The M3OS_SKIP_QEMU_TESTS
# env-var escape was removed because it let pre-existing regressions ride
# along with otherwise-clean commits (see PR #116, Phase 55b driver
# crash-loop incident).
#
# If you hit a genuine infra blocker (e.g., QEMU missing on a migration
# laptop), install QEMU + OVMF before pushing. In a true emergency
# `git push --no-verify` still works, but it is an explicit, visible
# opt-out — not an env-var that silently persists.

set -e

# Locate cargo — try PATH first, then ~/.cargo/env
if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    else
        echo "pre-push: cargo not found — install Rust toolchain before pushing" >&2
        exit 1
    fi
fi

echo "pre-push: running cargo xtask check..."
cargo xtask check

if ! command -v qemu-system-x86_64 >/dev/null 2>&1; then
    echo "pre-push: qemu-system-x86_64 not found — install QEMU and OVMF" >&2
    echo "          to run the full-system smoke + regression gates." >&2
    exit 1
fi

echo "pre-push: running cargo xtask smoke-test..."
cargo xtask smoke-test --timeout 300

echo "pre-push: running cargo xtask regression..."
cargo xtask regression --timeout 90
