#!/bin/sh
# Pre-push hook: run full quality gates before pushing to remote.
#
# The PR CI gate only runs static checks (clippy/fmt/host tests/loom) because
# GitHub's 2-vCPU shared runners can't execute TCG-emulated QEMU workloads
# reliably under Phase 54's IPC-heavy VFS. Full-system tests run here on
# developer hardware instead (and in the nightly workflow for scheduled
# coverage).
#
# Skipping the QEMU gates is not supported. The M3OS_SKIP_QEMU_TESTS
# env-var escape was removed because it let pre-existing regressions ride
# along with otherwise-clean commits (see PR #116, Phase 55b driver
# crash-loop incident).
#
# If you hit a genuine infra blocker (e.g., QEMU missing on a migration
# laptop), install QEMU + OVMF before pushing. In a true emergency
# `git push --no-verify` still works, but it is an explicit, visible
# opt-out — not an env-var that silently persists.
#
# Regression-suite flake handling (2026-04-25): `cargo xtask regression`
# runs every test back-to-back inside a single QEMU process pool, and the
# resulting resource contention occasionally produces spurious timeouts.
# The suite step below catches that pattern: if the all-tests run reports
# failures, each failing test is re-run with `--test <name>`, which
# launches a fresh QEMU. The push is rejected only when a test fails both
# in the suite *and* on its own. See post-mortem
# docs/post-mortems/2026-04-24-ingress-task-starvation.md, Lessons.

set -e

# Locate cargo — try PATH first, then ~/.cargo/env
if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    else
        echo "pre-push: cargo not found — install Rust toolchain before pushing" >&2
        exit 1
    fi
fi

echo "pre-push: running cargo xtask check..."
cargo xtask check

if ! command -v qemu-system-x86_64 >/dev/null 2>&1; then
    echo "pre-push: qemu-system-x86_64 not found — install QEMU and OVMF" >&2
    echo "          to run the full-system smoke + regression gates." >&2
    exit 1
fi

echo "pre-push: running cargo xtask smoke-test..."
cargo xtask smoke-test --timeout 300

echo "pre-push: running cargo xtask device-smoke --device nvme --iommu..."
cargo xtask device-smoke --device nvme --iommu --timeout 90

echo "pre-push: running cargo xtask device-smoke --device e1000 --iommu..."
cargo xtask device-smoke --device e1000 --iommu --timeout 90

echo "pre-push: running cargo xtask regression..."
# Suite-level QEMU contention occasionally causes spurious timeouts on
# individual tests (see docs/post-mortems/2026-04-24-ingress-task-starvation.md
# "Lessons" — cargo xtask regression is not test-isolated). When the suite
# reports failures, re-run each failing test in isolation; only declare a
# real failure if it still fails on a fresh QEMU. This preserves the
# regression gate's authority over genuine regressions while keeping the
# pre-push hook stable against the documented harness flakiness.
regression_log="$(mktemp)"
trap 'rm -f "$regression_log"' EXIT
# `set -e` would abort on the first failed cargo xtask invocation; disable
# it for the suite run so we can capture the per-test FAIL lines from the
# log and decide whether to retry them in isolation.
set +e
cargo xtask regression --timeout 90 2>&1 | tee "$regression_log"
suite_status=${PIPESTATUS:-$?}
set -e
if [ "$suite_status" -ne 0 ]; then
    failed_tests="$(grep -E '^  [a-z0-9_-]+: FAIL' "$regression_log" \
                    | sed -E 's/^  ([a-z0-9_-]+): FAIL.*/\1/')"
    if [ -z "$failed_tests" ]; then
        echo "pre-push: regression suite failed but no per-test FAIL lines parsed" >&2
        exit 1
    fi
    echo "pre-push: suite-level failures detected — re-running flakes in isolation:"
    for t in $failed_tests; do echo "          - $t"; done
    real_failures=""
    for t in $failed_tests; do
        echo "pre-push: isolated re-run: $t"
        if ! cargo xtask regression --test "$t" --timeout 90; then
            real_failures="$real_failures $t"
        fi
    done
    if [ -n "$real_failures" ]; then
        echo "pre-push: regression failures persisted in isolation:$real_failures" >&2
        exit 1
    fi
    echo "pre-push: all suite failures passed in isolation — treating as harness flakiness."
fi

if [ "${M3OS_E1000_REGRESSION:-0}" = "1" ]; then
    echo "pre-push: running cargo xtask ssh-e1000-banner-check..."
    cargo xtask ssh-e1000-banner-check --timeout 30
fi
