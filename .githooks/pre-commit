#!/bin/sh
# Pre-commit hook: run clippy + rustfmt check before every commit, plus
# the xtask-side host unit tests (fast — script-shape assertions that
# previously fell out of gate coverage because `cargo xtask check` only
# runs clippy/fmt/kernel-core).
#
# To bypass in an emergency: git commit --no-verify

set -e

# Locate cargo — try PATH first, then ~/.cargo/env
if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    else
        echo "pre-commit: cargo not found, skipping check"
        exit 0
    fi
fi

echo "pre-commit: running cargo xtask check..."
cargo xtask check

echo "pre-commit: running cargo test -p xtask..."
cargo test -p xtask --target x86_64-unknown-linux-gnu
