#!/bin/sh
# Pre-commit hook: run clippy + rustfmt check before every commit.
# To bypass in an emergency: git commit --no-verify

set -e

# Locate cargo — try PATH first, then ~/.cargo/env
if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    else
        echo "pre-commit: cargo not found, skipping check"
        exit 0
    fi
fi

echo "pre-commit: running cargo xtask check..."
cargo xtask check
